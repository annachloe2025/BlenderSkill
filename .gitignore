# ============================================================
# BlenderSkill .gitignore
# 大容量バイナリは GitHub に上げない方針
# ============================================================

# MkDocs ビルド成果物（gh-deploy が直接 push するので site/ は不要）
site/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# エディタ
.vscode/
.idea/
*.swp

# ============================================================
# Blender 関連（どこに置いても除外）
# ============================================================
*.blend
*.blend1
*.blend2
*.blend@

# ============================================================
# 3D アセット・モデル形式（どこに置いても除外）
# ============================================================
*.fbx
*.obj
*.mtl
*.stl
*.dae
*.abc
*.glb
*.gltf
*.usd
*.usda
*.usdc
*.usdz
*.ply
*.x3d

# ============================================================
# 大容量画像・テクスチャ・HDR（どこに置いても除外）
# ============================================================
*.exr
*.hdr
*.tga
*.tif
*.tiff
*.psd
*.psb
*.kra

# ============================================================
# 動画・音声（どこに置いても除外）
# ============================================================
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.wav
*.mp3
*.ogg
*.flac

# ============================================================
# レンダー成果物・出力フォルダ
# ============================================================
outputs/**/*.png
outputs/**/*.jpg
outputs/**/*.jpeg
!outputs/.gitkeep
renders/
cache/

# ============================================================
# ローカル専用バイナリ置き場（FBX素材・レンダー出力・blendファイル等）
# 中身は全部 git 対象外
# ============================================================
blender/

# ============================================================
# ただし docs/images/ の Web 用スクショ・図版は残す（PNG/JPG を許可）
# 上の outputs/* ルールには影響せず、docs/ 側だけ通す
# ============================================================
!docs/images/**/*.png
!docs/images/**/*.jpg
!docs/images/**/*.jpeg
!docs/images/**/*.svg
!docs/images/**/*.webp
